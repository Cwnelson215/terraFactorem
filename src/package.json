{
  "name": "terrafactorem",
  "version": "1.0.0",
  "description": "Generative map-making application",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"npx tsx watch index.ts\" \"cd client && npx vite\"",
    "build": "cd client && npx vite build && cd .. && tsc -p tsconfig.app.json",
    "build:client": "cd client && npx vite build",
    "build:server": "tsc -p tsconfig.app.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "simplex-noise": "^4.0.3",
    "three": "^0.169.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.0",
    "zustand": "^5.0.0"
  }
}
